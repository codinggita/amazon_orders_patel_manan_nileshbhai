{
  "name": "amazon-ecommerce-api",
  "version": "1.0.0",
  "description": "Amazon-style E-Commerce Backend API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon",
    "start:prod": "node src/server.js",
    "health": "node -e \"fetch('http://localhost:'+(process.env.PORT||5000)+'/api/v1/health').then(r=>r.json()).then(console.log).catch(console.error)\""
  },
  "keywords": ["ecommerce", "api", "express", "mongodb"],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
